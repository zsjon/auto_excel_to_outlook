# T-View Automation 환경변수 설정 예시
# 이 파일을 .env로 복사한 후 실제 값으로 변경하세요
# cp .env.example .env

# ─────────────────────────────────────────────────────────────
# 필수 설정
# ─────────────────────────────────────────────────────────────

# 운영 계정 이메일 (Outlook 로그인 계정)
OPERATOR_EMAIL=your-email@example.com

# 일일보고 수신자 (쉼표로 구분, 공백 없음)
REPORT_RECIPIENTS=manager@example.com,team-lead@example.com

# ─────────────────────────────────────────────────────────────
# 선택 설정
# ─────────────────────────────────────────────────────────────

# 일일보고 참조 (쉼표로 구분, 빈 값이면 참조 없음)
REPORT_CC=cc1@example.com,cc2@example.com

# 월간 장애 Excel 저장 디렉토리 (기본값: ./data/monthly_reports)
INCIDENT_EXCEL_DIR=./data/monthly_reports

# 일일보고 Excel 템플릿 경로 (기본값: ./data/daily_report.xlsx)
DAILY_REPORT_EXCEL_PATH=./data/daily_report.xlsx

# 장애 메일 감지 키워드 (쉼표로 구분)
# 제목 또는 본문에 이 키워드가 포함된 메일을 장애 메일로 분류
INCIDENT_MAIL_KEYWORDS=TiDC 운영팀,AT Platform DevOps,장애,점검 요청,리빌딩,황색 점등
